# Anvil environment variables
# Export these in your shell or service manager before running anvil.
# Example: export ANVIL_IDENTITY_WIF="Kx..."
# Anvil does NOT load .env files automatically — use your shell profile,
# systemd EnvironmentFile=, or `source .env && ./anvil`.

# ── Required ──
# BRC-42 identity key. This is the only thing you MUST set.
# Enables: wallet, mesh peering, overlay registration, API auth (derived automatically).
# Generate with any BSV wallet or: go run ./cmd/keygen (future)
ANVIL_IDENTITY_WIF=

# ── Optional: TAAL ARC failover ──
# GorillaPool ARC is the default (free, no key needed).
# Set a TAAL API key to add TAAL as a failover ARC endpoint.
# Get a key at: https://platform.taal.com
# ANVIL_TAAL_API_KEY=